# ── Identity ──────────────────────────────────────────────────────────────────
ENVIRONMENT=local          # prod | staging | local
SERVICE_NAME=my-service    # logical name of the service emitting these logs
HOSTNAME=localhost          # overrides the kernel hostname in log metadata

# ── Kafka ─────────────────────────────────────────────────────────────────────
# All three brokers listed so clients can bootstrap even if one is restarting.
KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092

# ── Fluent Bit ────────────────────────────────────────────────────────────────
FLB_LOG_LEVEL=info         # trace | debug | info | warn | error

# ── Log Generator (test only) ─────────────────────────────────────────────────
LOG_RATE=1000              # target events/sec split across file + TCP outputs
