# ═══════════════════════════════════════════════════════════════════════════════
# Log Monitoring Agent — environment variables
#
# Copy to .env and fill in the REQUIRED values before starting the stack:
#   cp .env.example .env
#
# REQUIRED  the stack will refuse to start without these (docker-compose uses :?)
# OPTIONAL  safe defaults provided for local development
# ═══════════════════════════════════════════════════════════════════════════════


# ── Identity ───────────────────────────────────────────────────────────────────
# Embedded in every Fluent Bit log record and tag.

ENVIRONMENT=local           # OPTIONAL  prod | staging | local
SERVICE_NAME=my-service     # OPTIONAL  logical name of the service emitting logs
HOSTNAME=localhost           # OPTIONAL  overrides the kernel hostname in log metadata


# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# Required by incident-reporter (Phase 3) to generate AI incident reports.

ANTHROPIC_API_KEY=          # REQUIRED  sk-ant-...


# ── JWT authentication (Dashboard API) ────────────────────────────────────────
# All /api/* endpoints require a Bearer JWT signed with this secret.
# Mint tokens with:  python api/issue_token.py <subject> [ttl_hours]

JWT_SECRET=                 # REQUIRED  ≥32 random characters
                            #   generate: python -c "import secrets; print(secrets.token_hex(32))"


# ── Rate limiting (Dashboard API) ─────────────────────────────────────────────

RATE_LIMIT_REQUESTS=100     # OPTIONAL  max requests per window per JWT subject
RATE_LIMIT_WINDOW_SECONDS=60 # OPTIONAL  sliding window length in seconds


# ── OpenSearch ────────────────────────────────────────────────────────────────
# Security plugin is disabled in the local stack; leave credentials empty.
# Set OPENSEARCH_HEAP to 1g or higher on machines with 16 GB+ RAM.

OPENSEARCH_USERNAME=        # OPTIONAL  leave empty for local (no auth)
OPENSEARCH_PASSWORD=        # OPTIONAL  leave empty for local (no auth)
OPENSEARCH_HEAP=512m        # OPTIONAL  JVM heap per opensearch container (e.g. 1g)


# ── Redis ──────────────────────────────────────────────────────────────────────

REDIS_MAXMEMORY=512mb       # OPTIONAL  allkeys-lru eviction above this limit


# ── Kafka ─────────────────────────────────────────────────────────────────────
# Hard-coded to the 3-node in-compose cluster; override only if using an
# external Kafka cluster.

KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092  # OPTIONAL


# ── Fluent Bit ────────────────────────────────────────────────────────────────

FLB_LOG_LEVEL=info          # OPTIONAL  trace | debug | info | warn | error


# ── Alert routing — Phase 4 ────────────────────────────────────────────────────
# Leaving either value empty disables that channel gracefully.

SLACK_BOT_TOKEN=            # OPTIONAL  xoxb-...  Bot OAuth token
PAGERDUTY_ROUTING_KEY=      # OPTIONAL  Events API v2 integration key
DASHBOARD_BASE_URL=http://localhost:5601  # OPTIONAL  base URL for Slack "View Dashboard" buttons

# ── Observability — Grafana (Phase 6 Part 2) ─────────────────────────────────
GRAFANA_ADMIN_USER=admin      # OPTIONAL  Grafana admin username  (default: admin)
GRAFANA_ADMIN_PASSWORD=admin  # OPTIONAL  Grafana admin password  (change in prod!)

# ── Observability — Self-monitoring alerts (Phase 6 Part 3) ──────────────────
# These are separate from the application-level keys in the alert_router (above).
# They are used by Alertmanager to fire alerts when the platform itself degrades.
#
# Alerts fired:
#   KafkaConsumerLagHigh     — lag > 100K messages for 2 min
#   EndToEndLatencyHigh      — p99 E2E latency > 60 s for 5 min
#   AnomalyDetectorSilent    — no detections scored for 5 min
#
PAGERDUTY_SELFMON_ROUTING_KEY=  # OPTIONAL  separate PagerDuty service for platform alerts
SLACK_SELFMON_WEBHOOK=          # OPTIONAL  incoming webhook URL for #incidents / #monitoring


# ── Log generator (load-test profile only) ────────────────────────────────────
# Not started by default.  Enable with:
#   docker compose --profile loadtest up

LOG_RATE=200                # OPTIONAL  synthetic log events per second
