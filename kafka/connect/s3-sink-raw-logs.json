{
  "connector.class":  "io.confluent.connect.s3.S3SinkConnector",
  "tasks.max":        "12",
  "topics":           "raw-logs",

  "storage.class":    "io.confluent.connect.s3.storage.S3Storage",
  "s3.region":        "us-east-1",
  "s3.bucket.name":   "log-archive",
  "store.url":        "http://localstack:4566",

  "format.class":             "io.confluent.connect.s3.format.bytearray.ByteArrayFormat",
  "bytearray.extension":      ".json",
  "bytearray.separator":      "\n",
  "s3.compression.type":      "gzip",

  "s3.part.size":             "67108864",

  "flush.size":                  "100000",
  "rotate.interval.ms":          "3600000",
  "rotate.schedule.interval.ms": "3600000",

  "locale":               "en_US",
  "timezone":             "UTC",
  "timestamp.extractor":  "Wallclock",
  "path.format":          "'year'=YYYY/'month'=MM/'day'=dd/'hour'=HH",
  "topics.dir":           "raw-logs",

  "key.converter":   "org.apache.kafka.connect.storage.StringConverter",
  "value.converter": "org.apache.kafka.connect.converters.ByteArrayConverter",

  "schema.compatibility": "NONE",

  "errors.tolerance":                              "all",
  "errors.deadletterqueue.topic.name":             "dead-letter-logs",
  "errors.deadletterqueue.context.headers.enable": "true",
  "errors.log.enable":                             "true",
  "errors.log.include.messages":                   "true",

  "consumer.override.max.poll.records": "1000",
  "consumer.override.fetch.max.bytes":  "52428800",
  "consumer.override.auto.offset.reset": "earliest"
}
