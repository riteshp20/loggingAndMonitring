{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "description": "End-to-end latency from log ingestion to alert delivery, API response times, and active client connections.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "End-to-End Latency (Log → Alert)",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Full path latency breakdown:\n• anomaly-detector processing_latency_seconds: baseline + detection + suppression + emit\n• incident-reporter report_pipeline_latency_seconds: enrich + PII scrub + Claude AI + OpenSearch store\n\nSLA target: sum p99 < 60 s",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Detection p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Report pipeline p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "End-to-end p99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(processing_latency_seconds_bucket[5m])))",
          "legendFormat": "Detection p99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(report_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "Report pipeline p99",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(processing_latency_seconds_bucket[5m]))) + histogram_quantile(0.99, sum by (le) (rate(report_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "End-to-end p99",
          "refId": "C"
        }
      ],
      "title": "End-to-End Latency p99",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current end-to-end p99. SLA target is 60 seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red",    "value": 60 }
            ]
          },
          "unit": "s",
          "max": 120,
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(processing_latency_seconds_bucket[5m]))) + histogram_quantile(0.99, sum by (le) (rate(report_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "E2E p99",
          "refId": "A"
        }
      ],
      "title": "E2E Latency p99 (SLA: 60 s)",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SLO compliance: percentage of 5-minute windows where end-to-end p99 was under 60 seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green",  "value": 99 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - clamp_min(histogram_quantile(0.99, sum by (le) (rate(processing_latency_seconds_bucket[5m]))) + histogram_quantile(0.99, sum by (le) (rate(report_pipeline_latency_seconds_bucket[5m]))) - 60, 0) / 60)",
          "legendFormat": "SLO %",
          "refId": "A"
        }
      ],
      "title": "SLO Compliance (E2E < 60 s)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p99 latency of the anomaly-detector pipeline alone (target: <500 ms).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red",    "value": 0.5 }
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(processing_latency_seconds_bucket[5m])))",
          "legendFormat": "Detection p99",
          "refId": "A"
        }
      ],
      "title": "Detection Pipeline p99",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p99 latency of the incident report pipeline (enrich + Claude AI + store). Dominated by the Claude API call (~2–10 s).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 30 }
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 10 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(report_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "Report p99",
          "refId": "A"
        }
      ],
      "title": "Report Pipeline p99",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "title": "API Response Times",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "API request latency percentiles across all routes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 6 },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 6,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "title": "API Request Duration",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p99 latency per API route — helps identify slow endpoints.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, path) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "API p99 by Route",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "HTTP error rate (4xx + 5xx) as a fraction of all requests.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 23 },
      "id": 8,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_errors_total[5m])) / (sum(rate(http_requests_total[5m])) + 0.0001)",
          "legendFormat": "Error rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_errors_total{status=~'5..'}[5m])) / (sum(rate(http_requests_total[5m])) + 0.0001)",
          "legendFormat": "5xx rate",
          "refId": "B"
        }
      ],
      "title": "API Error Rate",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 102,
      "title": "Live Connections",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of browsers / clients currently streaming from GET /api/stream/anomalies.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 200 }
            ]
          },
          "unit": "short",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 30 },
      "id": 9,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "active_sse_connections",
          "legendFormat": "SSE connections",
          "refId": "A"
        }
      ],
      "title": "Active SSE Connections",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "SSE connection count over time — helps identify connection storms or leaks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 30 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "active_sse_connections",
          "legendFormat": "Active connections",
          "refId": "A"
        }
      ],
      "title": "SSE Connection History",
      "type": "timeseries"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["log-monitor", "sla"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "System SLA",
  "uid": "log-monitor-sla",
  "version": 1
}
